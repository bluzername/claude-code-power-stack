#compdef ccs

# zsh completion for ccs (Claude Code Search)

_ccs() {
    local -a subcommands
    subcommands=(
        'here:Search current project only'
        'cheat:Quick reference card in terminal'
        'ls:List recent sessions'
        'go:Resume a session by number or ID'
        'stats:Show conversation stats dashboard'
        'doctor:Health check (Ghost, Ollama, index)'
        'team:Team activity, logging, and search'
        'update:Update the entire Power Stack'
        'ix:Re-index all conversations'
        'help:Show help'
    )

    if (( CURRENT == 2 )); then
        # First arg: subcommand or search query
        _describe 'subcommand' subcommands
        return
    fi

    case "${words[2]}" in
        go)
            if (( CURRENT == 3 )); then
                # Offer numbered results from cache
                local cache="$HOME/.ccs_last_results"
                if [[ -f "$cache" ]]; then
                    local -a sessions
                    local i=1
                    while IFS=$'\t' read -r sid proj; do
                        local label="${i} -- ${proj##*/} (${sid:0:8}...)"
                        sessions+=("${i}:${label}")
                        ((i++))
                    done < "$cache"
                    _describe 'session' sessions
                fi
            fi
            ;;
        ls)
            if (( CURRENT == 3 )); then
                local -a opts=('here:Current project only' '7:Last week' '14:Last 2 weeks' '30:Last month' '90:Last quarter')
                _describe 'options' opts
            fi
            ;;
        team)
            if (( CURRENT == 3 )); then
                local -a teamcmds=('standup:Morning team standup' 'log:Log a decision/finding/blocker' 'search:Search team log' 'sync:Commit and push team log' 'init:Initialize team mode' 'show:Show recent activity')
                _describe 'team command' teamcmds
            elif (( CURRENT == 4 )) && [[ "${words[3]}" == "log" ]]; then
                local -a types=('d:Decision' 'f:Finding' 'b:Blocker' 'done:Completed work' 'h:Handoff' 'decision:Technical choice' 'finding:Discovery' 'blocker:Blocking issue' 'handoff:Passing to teammate')
                _describe 'entry type' types
            fi
            ;;
        *)
            # Search flags
            _arguments \
                '-d[Limit to last N days]:days:' \
                '--days[Limit to last N days]:days:' \
                '--since[Start date]:date:' \
                '--until[End date]:date:' \
                '--date[Specific date]:date:' \
                '-p[Filter by project]:project:_directories' \
                '--project[Filter by project]:project:_directories' \
                '-n[Max results]:limit:'
            ;;
    esac
}

_ccs "$@"
