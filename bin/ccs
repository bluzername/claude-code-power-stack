#!/usr/bin/env bash
# ccs - Claude Code Search (shortcut for cc-conversation-search)
#
# Search results are numbered. Use "ccs go 1" to resume the first result.
#
#   ccs <query>              Search conversations (numbered results)
#   ccs <query> -d 7         Search last 7 days
#   ccs ls                   List recent sessions (7 days)
#   ccs go 1                 Resume result #1 from last search
#   ccs go <session-id>      Resume by full session ID
#   ccs ix                   Re-index all conversations
#   ccs help                 Show this help

set -euo pipefail

CCS_VERSION="1.1.0"
CCS_CACHE="${HOME}/.ccs_last_results"
CCS_REPO="${HOME}/.ccs_repo_path"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    -v|--version|version)
        echo "ccs $CCS_VERSION (Claude Code Power Stack)"
        ;;
    help|-h|--help)
        echo "ccs - Claude Code Search"
        echo ""
        echo "Usage:"
        echo "  ccs <query>              Search all projects (numbered)"
        echo "  ccs here <query>         Search current project only"
        echo "  ccs <query> -d 7         Search last 7 days"
        echo "  ccs ls                   List sessions (last 7 days)"
        echo "  ccs ls 30               List sessions (last 30 days)"
        echo "  ccs ls here              List current project only"
        echo "  ccs ls here 30           List current project, last 30 days"
        echo "  ccs go 1                 Resume result #1 from last search"
        echo "  ccs go <session-id>      Resume by full session ID"
        echo "  ccs stats                Show conversation stats dashboard"
        echo "  ccs doctor               Health check (Ghost, Ollama, index)"
        echo "  ccs cheat                Quick reference card in terminal"
        echo "  ccs update               Update the entire Power Stack"
        echo "  ccs ix                   Re-index all conversations"
        echo ""
        echo "Search flags:"
        echo "  -d, --days N             Limit to last N days"
        echo "  --since DATE             Start date (YYYY-MM-DD, yesterday, today)"
        echo "  --until DATE             End date"
        echo "  --date DATE              Specific date"
        echo "  -p, --project PATH       Filter by project path"
        echo "  -n, --limit N            Max results (default: 10)"
        ;;
    ls|list)
        project_filter=""
        if [ "${1:-}" = "here" ]; then
            project_filter="$(pwd)"
            shift
        fi
        days="${1:-7}"
        DB="${HOME}/.conversation-search/index.db"
        if [ ! -f "$DB" ]; then
            echo "No search index found. Run: ccs ix"
            exit 1
        fi
        python3 -c "
import sqlite3, os, sys
from datetime import datetime, timedelta

days = int(sys.argv[1])
project_filter = sys.argv[2] if len(sys.argv) > 2 else ''
db = os.path.expanduser('~/.conversation-search/index.db')
home = os.path.expanduser('~')
conn = sqlite3.connect(db)
c = conn.cursor()

cutoff = (datetime.now() - timedelta(days=days)).isoformat()

# Get sessions with stats
if project_filter:
    c.execute('''
        SELECT session_id, project_path,
               COUNT(*) as msg_count,
               MAX(timestamp) as last_ts
        FROM messages
        WHERE is_tool_noise = 0 AND timestamp > ? AND project_path = ?
        GROUP BY session_id
        ORDER BY last_ts DESC
    ''', (cutoff, project_filter))
else:
    c.execute('''
        SELECT session_id, project_path,
               COUNT(*) as msg_count,
               MAX(timestamp) as last_ts
        FROM messages
        WHERE is_tool_noise = 0 AND timestamp > ?
        GROUP BY session_id
        ORDER BY last_ts DESC
    ''', (cutoff,))
sessions = c.fetchall()

if not sessions:
    proj_short = project_filter.replace(home, '~') if project_filter else ''
    where = f' in {proj_short}' if proj_short else ''
    print(f'No sessions{where} in the last {days} days.')
    conn.close()
    sys.exit(0)

# Cache for ccs go
cache_path = os.path.expanduser('~/.ccs_last_results')
with open(cache_path, 'w') as f:
    for sid, proj, _, _ in sessions:
        f.write(f'{sid}\t{proj or \"\"}\n')

# Get first user message for each session as preview
previews = {}
for sid, _, _, _ in sessions:
    c.execute('''
        SELECT substr(full_content, 1, 80)
        FROM messages
        WHERE session_id = ? AND message_type = 'user'
          AND is_tool_noise = 0 AND is_meta_conversation = 0
          AND length(full_content) > 10
          AND full_content NOT LIKE '<command-%'
          AND full_content NOT LIKE 'Implement the following plan%'
          AND full_content NOT LIKE 'Base directory for this skill%'
        ORDER BY timestamp ASC LIMIT 1
    ''', (sid,))
    row = c.fetchone()
    previews[sid] = row[0].replace('\n', ' ').strip() if row else ''

conn.close()

proj_label = project_filter.replace(home, '~') if project_filter else ''
where = f' in {proj_label}' if proj_label else ''
print(f'\n  Sessions{where} (last {days} days)\n')
for i, (sid, proj, count, last_ts) in enumerate(sessions, 1):
    proj_short = (proj or '').replace(home, '~')
    ts = last_ts[:16].replace('T', ' ') if last_ts else ''
    preview = previews.get(sid, '')
    if len(preview) > 60:
        preview = preview[:57] + '...'

    print(f'\033[1;33m[{i}]\033[0m {ts}  \033[0;36m{proj_short}\033[0m  ({count} msgs)')
    if preview:
        print(f'    {preview}')
    print()

print(f'\033[0;32m{len(sessions)} sessions.\033[0m Resume with: ccs go 1')
print()
" "$days" "$project_filter" 2>&1
        ;;
    go|resume)
        if [ -z "${1:-}" ]; then
            echo "Usage: ccs go <N>          (resume result #N from last search)"
            echo "       ccs go <session-id> (resume by full ID)"
            exit 1
        fi
        target="$1"
        shift

        # If it's a small number, look up from cache
        if [[ "$target" =~ ^[0-9]+$ ]] && [ "$target" -le 100 ] 2>/dev/null; then
            if [ ! -f "$CCS_CACHE" ]; then
                echo "No previous search results. Run a search first: ccs <query>"
                exit 1
            fi
            line=$(sed -n "${target}p" "$CCS_CACHE")
            if [ -z "$line" ]; then
                total=$(wc -l < "$CCS_CACHE" | tr -d ' ')
                echo "Result #$target not found. Last search had $total results."
                exit 1
            fi
            session_id=$(echo "$line" | cut -f1)
            project_path=$(echo "$line" | cut -f2)
            echo "Resuming result #$target: $session_id"
            echo "  Project: $project_path"
            echo ""
            if [ -n "$project_path" ] && [ -d "$project_path" ]; then
                echo "cd $project_path && claude --resume $session_id"
                cd "$project_path" && exec claude --resume "$session_id"
            else
                echo "claude --resume $session_id"
                exec claude --resume "$session_id"
            fi
        else
            # Full session ID passed directly
            exec claude --resume "$target"
        fi
        ;;
    stats)
        DB="${HOME}/.conversation-search/index.db"
        if [ ! -f "$DB" ]; then
            echo "No search index found. Run: ccs ix"
            exit 1
        fi
        python3 -c "
import sqlite3, os
from datetime import datetime, timedelta

db = os.path.expanduser('~/.conversation-search/index.db')
conn = sqlite3.connect(db)
c = conn.cursor()

# Overall stats
c.execute('''SELECT COUNT(DISTINCT session_id), COUNT(*), COUNT(DISTINCT project_path)
             FROM messages WHERE is_tool_noise = 0''')
sessions, messages, projects = c.fetchone()

# This week
week_ago = (datetime.now() - timedelta(days=7)).isoformat()
c.execute('''SELECT COUNT(DISTINCT session_id), COUNT(*)
             FROM messages WHERE is_tool_noise = 0 AND timestamp > ?''', (week_ago,))
week_sessions, week_messages = c.fetchone()

# Top projects by session count
c.execute('''SELECT project_path, COUNT(DISTINCT session_id) as cnt, COUNT(*) as msgs
             FROM messages WHERE is_tool_noise = 0
             GROUP BY project_path ORDER BY cnt DESC LIMIT 8''')
top_projects = c.fetchall()

# Date range
c.execute('''SELECT MIN(timestamp), MAX(timestamp) FROM messages WHERE is_tool_noise = 0''')
earliest, latest = c.fetchone()
earliest_date = earliest[:10] if earliest else '?'
latest_date = latest[:10] if latest else '?'

conn.close()

# Display
print()
print('\033[1m  Claude Code Power Stack - Stats\033[0m')
print('  ' + '=' * 38)
print()
print(f'  \033[1;36mTotal\033[0m     {sessions} sessions / {messages:,} messages')
print(f'  \033[1;36mThis week\033[0m {week_sessions} sessions / {week_messages:,} messages')
print(f'  \033[1;36mProjects\033[0m  {projects} tracked')
print(f'  \033[1;36mRange\033[0m     {earliest_date} to {latest_date}')
print()
print('  \033[1mTop projects\033[0m')
print('  ' + '-' * 38)
for path, cnt, msgs in top_projects:
    short = path.replace(os.path.expanduser('~'), '~') if path else '(unknown)'
    # Truncate long paths from the left
    if len(short) > 28:
        short = '...' + short[-25:]
    bar = '\033[0;32m' + '#' * min(cnt, 20) + '\033[0m'
    print(f'  {short:<28s} {cnt:>3} {bar}')
print()
" 2>&1
        ;;
    doctor|health|check)
        OK='\033[0;32mOK\033[0m'
        WARN='\033[1;33mWARN\033[0m'
        FAIL='\033[0;31mFAIL\033[0m'
        pass=0; fail=0

        echo ""
        echo -e "  \033[1mPower Stack Health Check\033[0m"
        echo "  ========================="
        echo ""

        # Ghost binary
        if command -v ghost &>/dev/null; then
            echo -e "  $OK  ghost binary on PATH"
            ((pass++))
        else
            echo -e "  $FAIL  ghost binary not found"
            ((fail++))
        fi

        # Ghost MCP registered
        if claude mcp list 2>&1 | grep -q "ghost"; then
            echo -e "  $OK  Ghost MCP registered"
            ((pass++))
        else
            echo -e "  $FAIL  Ghost MCP not registered (run: claude mcp add ghost -s user -- \$(which ghost) mcp)"
            ((fail++))
        fi

        # Ollama running
        if curl -s --max-time 2 http://localhost:11434/api/tags &>/dev/null; then
            echo -e "  $OK  Ollama server running"
            ((pass++))

            # Embedding model
            if curl -s http://localhost:11434/api/tags 2>/dev/null | grep -q "nomic-embed-text"; then
                echo -e "  $OK  nomic-embed-text model available"
                ((pass++))
            else
                echo -e "  $FAIL  nomic-embed-text model missing (run: ollama pull nomic-embed-text)"
                ((fail++))
            fi
        else
            echo -e "  $FAIL  Ollama not running (run: ollama serve)"
            echo -e "  $WARN  skipping model check"
            ((fail++))
        fi

        # cc-conversation-search
        if command -v cc-conversation-search &>/dev/null; then
            echo -e "  $OK  cc-conversation-search installed"
            ((pass++))
        else
            echo -e "  $FAIL  cc-conversation-search not found"
            ((fail++))
        fi

        # Search index
        DB="${HOME}/.conversation-search/index.db"
        if [ -f "$DB" ]; then
            age_seconds=$(( $(date +%s) - $(stat -f%m "$DB" 2>/dev/null || stat -c%Y "$DB" 2>/dev/null || echo 0) ))
            age_hours=$(( age_seconds / 3600 ))
            if [ "$age_hours" -lt 24 ]; then
                echo -e "  $OK  search index fresh (updated ${age_hours}h ago)"
                ((pass++))
            else
                echo -e "  $WARN  search index stale (${age_hours}h old - run: ccs ix)"
                ((pass++))
            fi
        else
            echo -e "  $FAIL  search index missing (run: ccs ix)"
            ((fail++))
        fi

        # ccs shortcut
        if command -v ccs &>/dev/null; then
            echo -e "  $OK  ccs shortcut on PATH"
            ((pass++))
        else
            echo -e "  $FAIL  ccs not on PATH"
            ((fail++))
        fi

        # Planning files in current directory
        if [ -f "task_plan.md" ]; then
            phase=$(grep -c "Status.*in_progress\|Status.*pending" task_plan.md 2>/dev/null || echo 0)
            echo -e "  $OK  task_plan.md found in current dir ($phase phases remaining)"
        fi

        echo ""
        echo "  -------------------------"
        if [ "$fail" -eq 0 ]; then
            echo -e "  \033[0;32mAll $pass checks passed.\033[0m"
        else
            echo -e "  $pass passed, \033[0;31m$fail issues found\033[0m"
        fi
        echo ""
        ;;
    cheat|ref|quickref)
        B='\033[1m'     # bold
        C='\033[0;36m'  # cyan
        G='\033[0;32m'  # green
        Y='\033[1;33m'  # yellow
        P='\033[0;35m'  # purple
        N='\033[0m'     # reset
        echo ""
        echo -e "${B}  Claude Code Power Stack - Quick Reference${N}"
        echo "  ==========================================="
        echo ""
        echo -e "  ${Y}SESSION${N}"
        echo -e "    /standup                Morning standup summary"
        echo -e "    /rename-session         Name session: project-type-desc"
        echo -e "    /plan                   Create task_plan.md + findings.md + progress.md"
        echo ""
        echo -e "  ${C}SEARCH${N}"
        echo -e "    ccs \"query\"             Search all projects"
        echo -e "    ccs here \"query\"        Search current project only"
        echo -e "    ccs \"query\" -d 7        Last 7 days"
        echo -e "    ccs \"query\" --since DATE  Since specific date"
        echo ""
        echo -e "  ${G}NAVIGATE${N}"
        echo -e "    ccs go 1               Resume result #1 from last search"
        echo -e "    ccs ls                  List recent sessions (7 days)"
        echo -e "    ccs ls 30              List last 30 days"
        echo ""
        echo -e "  ${P}MAINTAIN${N}"
        echo -e "    ccs stats              Usage dashboard"
        echo -e "    ccs doctor             Health check"
        echo -e "    ccs update             Update the entire Power Stack"
        echo -e "    ccs ix                 Re-index conversations"
        echo -e "    ghost mcp status       Ghost MCP health"
        echo ""
        echo -e "  ${Y}PLANNING FILES (created by /plan)${N}"
        echo -e "    task_plan.md           Phases, decisions, errors"
        echo -e "    findings.md            Research notes (update every 2 searches!)"
        echo -e "    progress.md            Session log"
        echo ""
        echo -e "  ${B}SESSION NAMING${N}  {project}-{type}-{descriptor}"
        echo -e "  ${C}Types:${N} feat fix debug explore review plan research comms"
        echo -e "  ${C}Example:${N} api-feat-auth-flow, mobile-fix-crash"
        echo ""
        ;;
    update|upgrade)
        # Find the repo directory
        repo_dir=""
        if [ -f "$CCS_REPO" ]; then
            repo_dir="$(cat "$CCS_REPO")"
        fi
        # Fallback locations
        for dir in "$repo_dir" "${CLAUDE_POWER_STACK_DIR:-}" "${HOME}/.claude-power-stack"; do
            if [ -n "$dir" ] && [ -f "$dir/update.sh" ]; then
                exec bash "$dir/update.sh"
            fi
        done
        echo "Could not find Power Stack repo."
        echo "Set the path: echo '/path/to/claude-code-power-stack' > ~/.ccs_repo_path"
        echo "Or re-install: curl -fsSL https://raw.githubusercontent.com/bluzername/claude-code-power-stack/main/setup.sh | bash"
        exit 1
        ;;
    ix|index|reindex)
        cc-conversation-search index --all
        ;;
    here)
        # Search scoped to current project directory
        query="${1:-}"
        if [ -z "$query" ]; then
            echo "Usage: ccs here <query>"
            echo "Searches only sessions from: $(pwd)"
            exit 1
        fi
        shift
        # Re-invoke ourselves with -p set to pwd
        exec "$0" "$query" -p "$(pwd)" "$@"
        ;;
    *)
        # Default: search, show numbered results, cache session IDs
        args=()
        query="$cmd"
        while [ $# -gt 0 ]; do
            case "$1" in
                -d) args+=("--days" "$2"); shift 2 ;;
                -p) args+=("--project" "$2"); shift 2 ;;
                -n) args+=("--limit" "$2"); shift 2 ;;
                *)  args+=("$1"); shift ;;
            esac
        done

        # Check prerequisites
        if ! command -v cc-conversation-search &>/dev/null; then
            echo "cc-conversation-search not installed. Run: ccs update"
            exit 1
        fi
        if [ ! -f "${HOME}/.conversation-search/index.db" ]; then
            echo "No search index. Building it now..."
            cc-conversation-search init 2>&1 | tail -3
        fi

        # Run search in JSON mode to extract session IDs
        json_output=$(cc-conversation-search search "$query" --json --limit "${limit:-10}" ${args[@]+"${args[@]}"} 2>&1)

        # Parse unique sessions and cache them
        if command -v python3 &>/dev/null; then
            echo "$json_output" | python3 -c "
import json, sys
from collections import OrderedDict

try:
    results = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    results = []

if not results:
    print('No sessions found for that query.')
    sys.exit(0)

# Deduplicate by session_id, preserve order
seen = OrderedDict()
for r in results:
    sid = r.get('session_id', '')
    if sid and sid not in seen:
        seen[sid] = r

# Write cache file
cache_path = '$CCS_CACHE'
with open(cache_path, 'w') as f:
    for sid, r in seen.items():
        proj = r.get('project_path', '')
        f.write(f'{sid}\t{proj}\n')

# Display numbered results
for i, (sid, r) in enumerate(seen.items(), 1):
    proj = r.get('project_path', '').replace('$HOME', '~')
    ts = r.get('timestamp', '')[:16].replace('T', ' ')
    snippet = r.get('context_snippet', '')[:120].replace('\n', ' ')
    print(f'\033[1;33m[{i}]\033[0m {ts}  \033[0;36m{proj}\033[0m')
    print(f'    {sid}')
    if snippet:
        print(f'    {snippet}...')
    print()

total = len(seen)
if total > 0:
    print(f'\033[0;32m{total} sessions found.\033[0m Resume with: ccs go 1')
" 2>&1
        else
            # Fallback: just run normal search (no numbering)
            cc-conversation-search search "$query" ${args[@]+"${args[@]}"}
        fi
        ;;
esac
