#!/usr/bin/env bash
# ccs - Claude Code Search (shortcut for cc-conversation-search)
# Usage:
#   ccs <query>                  Search conversations
#   ccs <query> -d 7             Search last 7 days
#   ccs <query> --since 2025-03  Search since date
#   ccs ls                       List recent sessions (7 days)
#   ccs ls 30                    List recent sessions (30 days)
#   ccs go <session-id>          Resume a session
#   ccs ix                       Re-index all conversations
#   ccs help                     Show this help

set -euo pipefail

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    help|-h|--help)
        echo "ccs - Claude Code Search"
        echo ""
        echo "Usage:"
        echo "  ccs <query>              Search conversations"
        echo "  ccs <query> -d 7         Search last 7 days"
        echo "  ccs <query> -p ~/proj    Search specific project"
        echo "  ccs ls                   List sessions (last 7 days)"
        echo "  ccs ls 30               List sessions (last 30 days)"
        echo "  ccs go <session-id>      Resume a session"
        echo "  ccs ix                   Re-index all conversations"
        echo ""
        echo "Search flags (pass through to cc-conversation-search):"
        echo "  -d, --days N             Limit to last N days"
        echo "  --since DATE             Start date (YYYY-MM-DD, yesterday, today)"
        echo "  --until DATE             End date"
        echo "  --date DATE              Specific date"
        echo "  -p, --project PATH       Filter by project path"
        echo "  -n, --limit N            Max results (default: 20)"
        ;;
    ls|list)
        days="${1:-7}"
        cc-conversation-search list --days "$days"
        ;;
    go|resume)
        if [ -z "${1:-}" ]; then
            echo "Usage: ccs go <session-id>"
            exit 1
        fi
        echo "Run: claude --resume $1"
        claude --resume "$1"
        ;;
    ix|index|reindex)
        cc-conversation-search index --all
        ;;
    *)
        # Default: treat as search query
        # Reassemble args, translating short flags
        args=()
        query="$cmd"
        while [ $# -gt 0 ]; do
            case "$1" in
                -d) args+=("--days" "$2"); shift 2 ;;
                -p) args+=("--project" "$2"); shift 2 ;;
                -n) args+=("--limit" "$2"); shift 2 ;;
                *)  args+=("$1"); shift ;;
            esac
        done
        cc-conversation-search search "$query" "${args[@]}"
        ;;
esac
